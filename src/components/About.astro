---
import { getTranslations } from "@/i18n";

const lang = Astro.locals.lang;
const t = getTranslations(lang);
---

<section id="About" class="container mx-auto mb-28 p-6">
    <h2 class="heading text-5xl md:text-9xl uppercase">{t.about.title}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 items-center md:p-0 gap-8">
        <div class="space-y-6">
            <div
                class="w-full aspect-square md:max-w-[500px] overflow-hidden rounded-3xl"
            >
                <img
                    src="/portrait.webp"
                    alt="Nikita"
                    class="w-full h-full object-cover"
                />
            </div>
        </div>

        <div>
            <div class="text-lg md:text-2xl text-secondary space-y-4">
                <p>
                    {t.about.description}
                </p>
            </div>
            <div>
                <h3 class="heading text-2xl uppercase my-8 text-secondary">
                    {t.about.techStack}
                </h3>
                <div class="flex flex-wrap gap-4 mt-8">
                    <span
                        class="inline-flex items-center justify-center rounded-4xl py-4 px-8 outline-1 outline-dashed outline-secondary"
                    >
                        {t.about.tech.llm}
                    </span>
                    <span
                        class="inline-flex items-center justify-center rounded-4xl py-4 px-8 outline-1 outline-dashed outline-secondary"
                    >
                        {t.about.tech.smartContracts}
                    </span>
                    <span
                        class="inline-flex items-center justify-center rounded-4xl py-4 px-8 outline-1 outline-dashed outline-secondary"
                    >
                        {t.about.tech.rag}
                    </span>
                    <span
                        class="inline-flex items-center justify-center rounded-4xl py-4 px-8 outline-1 outline-dashed outline-secondary"
                    >
                        {t.about.tech.onchain}
                    </span>
                    <span
                        class="inline-flex items-center justify-center rounded-4xl py-4 px-8 outline-1 outline-dashed outline-secondary"
                    >
                        {t.about.tech.defi}
                    </span>
                    <span
                        class="inline-flex items-center justify-center rounded-4xl py-4 px-8 outline-1 outline-dashed outline-secondary"
                    >
                        {t.about.tech.product}
                    </span>
                    <span
                        class="inline-flex items-center justify-center rounded-4xl py-4 px-8 outline-1 outline-dashed outline-secondary"
                    >
                        {t.about.tech.mvp}
                    </span>
                    <span
                        class="inline-flex items-center justify-center rounded-4xl py-4 px-8 outline-1 outline-dashed outline-secondary"
                    >
                        {t.about.tech.vibeCoding}
                    </span>
                </div>
            </div>
        </div>
    </div>
</section>
