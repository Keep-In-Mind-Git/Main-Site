---
import { SITE } from "@/consts";
---

<section
    class="grid grid-cols-1 lg:grid-cols-2 items-center container mx-auto min-h-screen p-6 md:gap-16 gap-8 pt-24"
>
    <h1 class="heading text-[clamp(3rem,12vw,8rem)] uppercase leading-[0.9]">
        Строю AI-продукты<br/>для FinTech и Crypto
    </h1>
    <div class="space-y-8">
        <p class="text-2xl text-secondary">
            Никита · AI · MVP за 2 недели. <br>
            Crypto · DeFi · Фонда · Анализ рынков.
        </p>
        <div class="flex flex-col md:flex-row gap-2.5">
            <a
                class="w-full sm:w-auto flex items-center justify-center bg-primary rounded-2xl py-3 px-6 sm:py-4 sm:px-10 cursor-pointer hover:bg-background hover:outline hover:outline-1 hover:outline-dashed hover:outline-secondary hover:text-foreground transition"
                href="/projects">Смотреть кейсы</a
            >
            <a
                class="w-full sm:w-auto flex items-center justify-center bg-foreground text-background rounded-2xl py-3 px-6 sm:py-4 sm:px-10 cursor-pointer hover:bg-background hover:outline hover:outline-1 hover:outline-dashed hover:outline-secondary hover:text-foreground transition"
                href={`mailto:${SITE.EMAIL}`}>Обсудить сотрудничество</a
            >
        </div>
    </div>
</section>
